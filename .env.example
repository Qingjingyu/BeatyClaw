# Agentic owner login
AGENTIC_OWNER_EMAIL=owner@example.com
AGENTIC_OWNER_PASSWORD=change-me
AGENTIC_OWNER_NAME=Owner

# Legacy token login is disabled by default.
# Set this only for temporary migration/debug compatibility.
AGENTIC_ALLOW_TOKEN_AUTH=0

# Server-side runtime secrets. Never expose these in the frontend.
OPENAI_API_KEY=
OPENAI_BASE_URL=
AGENTIC_DEFAULT_MODEL=gpt-5.5
AGENTIC_DISABLE_HERMES_GATEWAY=1
HERMES_BIN=/opt/hermes/.venv/bin/hermes
AGENTIC_HXA_RUNTIME_ENABLED=0
AGENTIC_HXA_BASE_URL=
# Use an hxa-connect bot/client token allowed to call /api/send, not the admin secret.
AGENTIC_HXA_TOKEN=
AGENTIC_HXA_MAIN_BOT=zylos-main
AGENTIC_HXA_REPLY_TIMEOUT_MS=20000
AGENTIC_HXA_POLL_INTERVAL_MS=1000
# Default product-shell mode: BeatyClaw runs without an installed AI engine.
# Set to zylos/openai-direct/hms/openclaw only after the engine adapter is installed.
BEATYCLAW_RUNTIME_PROVIDER=none
# HMS employee runtime installer. Use hermes-gateway when deploying a real HMS employee engine.
BEATYCLAW_HMS_INSTALL_MODE=
BEATYCLAW_HMS_PORT=
BEATYCLAW_HMS_HOST=127.0.0.1
BEATYCLAW_HMS_HEALTH_URL=
BEATYCLAW_HMS_START_COMMAND=
BEATYCLAW_HMS_START_ARGS=

# External connector credentials. Keep these only on the server or mounted env file.
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_RUNTIME_WATCHDOG_MS=30000
TELEGRAM_BOT_TOKEN=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Product stability checks.
BEATYCLAW_HEALTHCHECK_URL=http://127.0.0.1:6060/api/hermes/runtime/status
ZYLOS_MAIN_RUNTIME_ENABLED=0
ZYLOS_MAIN_HXA_BASE_URL=
ZYLOS_MAIN_HXA_TOKEN=
ZYLOS_MAIN_BOT_NAME=zylos-main
ZYLOS_MAIN_WORKER_BOT=worker-bot
ZYLOS_MAIN_WORKER_TIMEOUT_MS=10000
ZYLOS_MAIN_WORKER_POLL_INTERVAL_MS=1000
ZYLOS_MAIN_KANBAN_BOARD=default
ZYLOS_MAIN_MODEL=gpt-5.5
HXA_WORKER_BOT_ENABLED=0
HXA_URL=
HXA_TOKEN=
TARGET_BOT=zylos-main
BOT_NAME=worker-bot
KANBAN_BOARD=default
ZYLOS_BASE_URL=
HXA_CONNECT_BASE_URL=
HXA_CONNECT_ADMIN_SECRET=
COCO_BASE_URL=
COCO_API_KEY=

# Optional data locations
YOYOO_AUTH_HOME=
YOYOO_SPACES_ROOT=
